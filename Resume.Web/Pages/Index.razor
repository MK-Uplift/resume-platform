<!-- CONTACT -->
<section class="section-sm" id="contact">
    <div class="contact-section">
        <div>
            <div class="section-label">Get Started</div>
            <h2 class="section-title">Ready to connect?</h2>
            <p class="section-desc">
                Tell me about the role or challenge you're working on. I'll get back to you promptly.
            </p>

            <div class="contact-email-row">
                <div class="contact-email-icon">✉️</div>
                <div>
                    <div class="contact-email-label">Email directly</div>
                    <div class="contact-email-value">michaelmk1122@gmail.com</div>
                </div>
            </div>

            <div class="contact-links">
                <a class="contact-link-btn" href="https://www.linkedin.com/in/-michael-li/" target="_blank" rel="noopener">
                    LinkedIn ↗
                </a>
                <a class="contact-link-btn" href="https://github.com/MK-Uplift" target="_blank" rel="noopener">
                    GitHub ↗
                </a>
            </div>
        </div>

        <div class="contact-form" id="contact-form">
            @if (!string.IsNullOrEmpty(submitMessage))
            {
                <div class="@(submitSuccess ? "alert-success" : "alert-error")">
                    @submitMessage
                </div>
            }

            <EditForm Model="@contactForm" OnValidSubmit="@HandleSubmit">
                <DataAnnotationsValidator />

                <div class="form-row">
                    <div class="form-group">
                        <label>Name</label>
                        <InputText class="form-input" @bind-Value="contactForm.Name" placeholder="Your name" />
                        <ValidationMessage For="@(() => contactForm.Name)" />
                    </div>
                    <div class="form-group">
                        <label>Email</label>
                        <InputText class="form-input" @bind-Value="contactForm.Email" placeholder="you@company.com" />
                        <ValidationMessage For="@(() => contactForm.Email)" />
                    </div>
                </div>

                <div class="form-group">
                    <label>Message</label>
                    <InputTextArea class="form-input" @bind-Value="contactForm.Message" placeholder="Tell me about the role or project..." rows="5" />
                    <ValidationMessage For="@(() => contactForm.Message)" />
                </div>

                <button type="submit" class="btn-submit" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span>Sending...</span>
                    }
                    else
                    {
                        <span>Send Message ↗</span>
                    }
                </button>
            </EditForm>
        </div>
    </div>
</section>

<footer class="footer">
